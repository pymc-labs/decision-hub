# Environment: set DHUB_ENV=dev or DHUB_ENV=prod (default: prod)
# The server loads .env.{DHUB_ENV} automatically (e.g. .env.dev, .env.prod)

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/decision_hub

# S3 Storage
S3_BUCKET=decision-hub-skills
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret

# GitHub OAuth (Device Flow)
GITHUB_CLIENT_ID=your-github-client-id

# JWT
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8760

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=your-fernet-key

# Sprint 3: Modal
# MODAL_APP_NAME=decision-hub

# Sprint 4: Gemini Search
# GOOGLE_API_KEY=your-google-api-key
# GEMINI_MODEL=gemini-2.0-flash

# Authorization: restrict login to members of a GitHub org (leave empty to
# allow all GitHub users). This is an authorization check at login time —
# authentication (valid JWT) is always required on write endpoints regardless.
# REQUIRE_GITHUB_ORG=pymc-labs

# CLI version management
# MIN_CLI_VERSION=0.2.0
# LATEST_CLI_VERSION=0.2.0

# Logging (DEBUG, INFO, WARNING, ERROR). Default: INFO.
# LOG_LEVEL=INFO
